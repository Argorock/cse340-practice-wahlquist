<%- include('../partials/header') %>

<h1>Faculty Directory</h1>

<p>Sorted by: <strong><%= currentSort %></strong></p>

<nav>
  <a href="/faculty?sort=name">Sort by Name</a> |
  <a href="/faculty?sort=department">Sort by Department</a> |
  <a href="/faculty?sort=title">Sort by Title</a>
</nav>

<ul>
  <% faculty.forEach(member => { %>
    <li>
      <a href="/faculty/<%= member.id %>"><%= member.name %></a>
      — <%= member.department %> — <%= member.title %>
    </li>
  <% }) %>
</ul>

<p><a href="/">Back to Home</a></p>

<%- include('../partials/footer') %>
